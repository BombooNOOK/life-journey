generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 注文（鑑定1件）。後から製本直送APIへ渡す想定で住所・連絡先を保持
model Order {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lastName       String
  firstName      String
  lastNameKana   String
  firstNameKana  String
  lastNameRoman  String
  firstNameRoman String
  fullNameDisplay     String
  fullNameKanaDisplay String
  fullNameRomanDisplay String

  birthDate  String /// YYYY-MM-DD
  birthYear  Int
  birthMonth Int
  birthDay   Int

  postalCode String
  address    String
  phone      String
  email      String
  profileId  String @default("")

  numerologyJson String
  stonesJson     String
  /// フォーム「今いちばん関心のあること」（石候補の同順位内の優先のみ）
  stoneFocusTheme String @default("特に決まっていない")

  reportPdfPath  String?
  /// 鑑定フルPDF（プレビュー画質）を Vercel Blob に保存したときの URL。`focus=all`・`bodyTune=normal` のみ。
  pdfPreviewBlobUrl   String?
  /// `pdfPreviewBlobUrl` がどの注文内容に対応するか（SHA256）。内容変更時は再生成して上書き。
  pdfPreviewCacheKey  String?
  /// 鑑定フルPDF（製本・高画質）の Blob URL。条件は pdfPreview と同じ。
  pdfPrintBlobUrl     String?
  pdfPrintCacheKey    String?
  pdfDownloadCount Int @default(0)
  pdfDownloadLimit Int @default(2)

  /// 氏名・生年月日の救済修正を何回使ったか（0 のときのみ修正可能）
  identityCorrectionCount Int @default(0)

  /// 旧Excel等との突合用。任意JSON（コア5項目の期待値など）
  expectedNumerologyJson String?

  status String @default("draft")

  @@index([email, profileId])
}

model JournalEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email         String
  profileId     String @default("")
  content       String
  mood          String @default("calm")
  activity      String @default("record_anyway")
  companionType String @default("owl")
  designTheme   String @default("cute")
  photoDataUrl  String?
  generatedComment String?
  includeInBook Boolean @default(true)

  @@index([email, profileId])
}

/// 本棚の「年別日記」ごとの表示名・表紙・製本期間（その西暦年内の月レンジ）
model DiaryBookshelfBook {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email String
  profileId String @default("")
  year  Int

  displayTitle     String?
  coverTheme       String @default("simple")
  periodStartMonth Int    @default(1)
  periodEndMonth   Int    @default(12)

  @@unique([email, profileId, year])
  @@index([email, profileId])
}

/// ユーザー単位の運用設定（管理者判定・プロフィール上限など）
model AccountSettings {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email        String @unique
  isAdmin      Boolean @default(false)
  profileLimit Int     @default(1)
  /// 鑑定書PDFの無料ダウンロード上限（鑑定1件あたり）。新規鑑定作成時と管理者変更時に Order に反映する。
  pdfDownloadLimitPerOrder Int @default(2)
  /// 製本用（高画質）鑑定書PDFのダウンロード可否（プレビュー版は全員）
  subscriberPdfAccess Boolean @default(false)
}

/// 1アカウント配下のプロフィール（ニックネーム表示用）
model Profile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email      String
  nickname   String
  isArchived Boolean @default(false)

  @@index([email, isArchived])
}
