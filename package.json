{
  "name": "numerology-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:fresh": "node scripts/kill-port.mjs 3000 && rm -rf .next node_modules/.cache && next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:sync": "prisma db push && prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "build:vercel": "prisma generate && next build",
    "postinstall": "prisma generate && patch-package",
    "test": "vitest run",
    "verify:print": "npx tsx scripts/print-numerology.ts",
    "dump:bodies": "npx tsx scripts/dump-numerology-body-text.ts",
    "dump:bridge-comments": "npx tsx scripts/dump-bridge-score-comments.ts",
    "pdf:sample:text": "npx tsx scripts/print-sample-booklet-text.ts",
    "pdf:sample": "npx tsx scripts/render-sample-booklet.tsx && node scripts/open-sample-pdf-in-editor.mjs",
    "build:stone-pdf-data": "node scripts/extractStonePdfText.mjs && node scripts/parseStonePdfV4.mjs",
    "fix:lp-bg-header": "python3 scripts/transparentizeCoreFirstPageHeaderBand.py src/components/pdf/assets/haikei-lp.png",
    "fix:destiny-bg-header": "python3 scripts/transparentizeCoreFirstPageHeaderBand.py src/components/pdf/assets/destiny-first-page.png",
    "fix:soul-bg-header": "python3 scripts/transparentizeCoreFirstPageHeaderBand.py src/components/pdf/assets/soul-first-page.png",
    "fix:personality-bg-header": "python3 scripts/transparentizeCoreFirstPageHeaderBand.py src/components/pdf/assets/personality-first-page.png",
    "fix:birthday-bg-header": "python3 scripts/transparentizeCoreFirstPageHeaderBand.py src/components/pdf/assets/birthday-first-page.png",
    "fix:maturity-bg-header": "python3 scripts/transparentizeCoreFirstPageHeaderBand.py src/components/pdf/assets/maturity-first-page.png",
    "pdf:preview-assets": "node scripts/build-pdf-preview-assets.mjs"
  },
  "dependencies": {
    "@fontsource/noto-sans-jp": "^5.2.5",
    "@prisma/client": "^6.6.0",
    "@react-pdf/renderer": "^4.3.0",
    "@vercel/blob": "^0.27.3",
    "firebase": "^11.10.0",
    "next": "^15.2.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.2.0",
    "patch-package": "^8.0.1",
    "pdf-parse": "^1.1.1",
    "prisma": "^6.6.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
