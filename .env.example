# このファイルをコピーして `.env.local` にリネームし、
# 右側の値を Firebase コンソールの「ウェブアプリの設定」から貼ってください。
# （.env.local は Git に上げないので安心です）

# DB 接続先。ローカル開発は SQLite のままでもOKです。
# 例（ローカル）: DATABASE_URL="file:./prisma/dev.db"
# 例（本番）: DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DATABASE_URL=

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# あれば（なくても動きます）
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# BASE 製本ショップ商品 URL（本棚「この内容で注文する」ボタン用）。未設定時はプレースホルダー URL。
# NEXT_PUBLIC_BASE_BOOK_TRIAL_URL=https://your-shop.base.shop/items/...
# NEXT_PUBLIC_BASE_BOOK_LIGHT_URL=
# NEXT_PUBLIC_BASE_BOOK_STANDARD_URL=
# NEXT_PUBLIC_BASE_BOOK_EXTRA_URL=
# 鑑定書PDFの無料回数超過時に案内する再発行商品ページ（任意）
# NEXT_PUBLIC_BASE_PDF_REISSUE_URL=

# 管理者用メール（カンマ区切り）。/admin ページへのアクセス許可に使います。
# ADMIN_EMAILS=owner@example.com,staff@example.com
